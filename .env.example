# ============================================
# SERVER CONFIGURATION
# ============================================
PORT=5000
NODE_ENV=production

# ============================================
# DATABASE - MongoDB Atlas (Cloud)
# ============================================
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/<database-name>?retryWrites=true&w=majority

# ============================================
# FILE STORAGE - Supabase (Cloud)
# ============================================
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_STORAGE_BUCKET=media

# ============================================
# AUTHENTICATION & SECURITY
# ============================================
JWT_SECRET=replace-with-a-long-random-secret
INIT_ADMIN_EMAIL=admin@example.com
INIT_ADMIN_PASSWORD=ChangeMe123!

# ============================================
# EMAIL SERVICE - Resend
# ============================================
# Get your API key from: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxx

# FROM_EMAIL: Must be a verified domain in Resend
# For custom domain: noreply@aditishrimankar.com
# For testing: onboarding@resend.dev
FROM_EMAIL=noreply@aditishrimankar.com

# ADMIN_EMAIL: Your email where contact form messages will be sent
ADMIN_EMAIL=aditi1411ss@gmail.com

# ============================================
# FRONTEND CONFIGURATION
# ============================================
FRONTEND_URL=https://aditishrimankar.com
ALLOWED_ORIGINS=https://aditishrimankar.com,https://www.aditishrimankar.com,http://localhost:5173,http://localhost:3000
